---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  accent?: string;
}
const {
  title,
  description = 'Průvodce světem retro hraní — historie herních platforem, legendární hry a tipy pro handheldy a Batoceru.',
  accent,
} = Astro.props;
const fullTitle = title === 'RetroWeb' ? title : `${title} · RetroWeb`;
---

<!doctype html>
<html lang="cs" style={accent ? `--accent:${accent}` : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="IDrnXf4SnlflFK5cWHt2-iOCWeffYIzIWS8mrm6m6xk" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (!t) t = matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
          if (t === 'light') document.documentElement.setAttribute('data-theme', 'light');
        } catch (e) {}
      })();
    </script>
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {
      import.meta.env.PROD && (
        <>
          <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-P1699EJJD9"></script>
          <script is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());
            gtag('config', 'G-P1699EJJD9');
          </script>
        </>
      )
    }
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
