---
import Base from '../../layouts/Base.astro';
import GameCard from '../../components/GameCard.astro';
import {
  allGames,
  getGame,
  FLAG_LABEL,
  LENGTH_LABEL,
  mdBlock,
  mdInline,
} from '../../lib/data';

export function getStaticPaths() {
  return allGames.map((g) => ({ params: { slug: g.slug } }));
}

const { slug } = Astro.params;
const game = getGame(slug!)!;
const platform = game.platform;

// Pár dalších her ze stejné platformy
const related = platform.games.filter((g) => g.slug !== game.slug).slice(0, 3);
const nameHtml = mdInline(game.name);
const genreNote = game.genre ? ` jako zástupce žánru ${game.genre}` : '';
// Galerie = záběry ze hry a titulní obrazovka (obal je už v hlavičce)
const shots = game.gallery.filter((g) => g.kind !== 'box');
---

<Base
  title={game.name.replace(/[*_\x60]/g, '')}
  description={game.teaser ?? (game.detail ? game.detail.replace(/[*_\x60]/g, '').slice(0, 155) : `${game.name} pro ${platform.name}.`)}
  accent={platform.color}
>
  <article class="container narrow">
    <nav class="crumbs muted" aria-label="Drobečková navigace">
      <a href="/hry">Hry</a> <span>/</span>
      <a href={`/platformy/${platform.slug}`}>{platform.name}</a> <span>/</span>
      <span>{game.name.replace(/[*_\x60]/g, '')}</span>
    </nav>

    <header class:list={['head', { 'has-art': game.image }]}>
      {
        game.image && (
          <div class="boxart" style={`--c1:${platform.color}; --c2:${platform.color2}`}>
            <img src={game.image} alt={`${game.name.replace(/[*_\x60]/g, '')} – boxart`} decoding="async" />
          </div>
        )
      }
      <div class="head-text">
        <a class="platform-pill" href={`/platformy/${platform.slug}`} style={`--c1:${platform.color}`}>
          <span class="pp-short pixel">{platform.short}</span>
          {platform.name}
        </a>
        <h1 set:html={nameHtml} />

        <div class="facts">
          {game.genre && <span class="tag tag-genre" style={`--c1:${platform.color}`}>{game.genre}</span>}
          {game.year && <span class="tag">{game.year}</span>}
          {game.studio && <span class="tag">{game.studio}</span>}
          {game.length && <span class="tag">{LENGTH_LABEL[game.length]}</span>}
          {game.est && <span class="tag">⏱ cca {game.est}</span>}
          {game.flags.map((f) => <span class="tag tag-flag">{FLAG_LABEL[f]}</span>)}
        </div>
      </div>
    </header>

    {game.teaser && (
      <p class="teaser" set:html={mdInline(game.teaser)}></p>
    )}

    {
      game.article ? (
        <div class="prose detail article" set:html={mdBlock(game.article)} />
      ) : game.detail ? (
        <div class="prose detail" set:html={mdBlock(game.detail)} />
      ) : (
        <div class="no-detail">
          <p class="muted">
            U téhle hry zatím nemáme delší komentář. Patří ale do kurátorského výběru
            pro <a href={`/platformy/${platform.slug}`}>{platform.name}</a>{genreNote}.
          </p>
        </div>
      )
    }

    {
      shots.length > 0 && (
        <section class="gallery">
          <h2>Galerie</h2>
          <div class="shots">
            {shots.map((s) => (
              <figure>
                <img src={s.src} alt={`${game.name.replace(/[*_\x60]/g, '')} – ${s.label}`} loading="lazy" decoding="async" />
                <figcaption>{s.label}</figcaption>
              </figure>
            ))}
          </div>
        </section>
      )
    }

    {
      related.length > 0 && (
        <section class="related">
          <h2>Další z {platform.name}</h2>
          <div class="grid grid-games">
            {related.map((g) => (
              <GameCard game={g} platform={platform} />
            ))}
          </div>
          <a class="btn back" href={`/platformy/${platform.slug}`}>
            ← Všech {platform.gameCount} her pro {platform.name}
          </a>
        </section>
      )
    }
  </article>
</Base>

<style>
  .narrow {
    max-width: 800px;
  }
  .crumbs {
    padding-top: 26px;
    font-size: 0.86rem;
  }
  .crumbs a:hover {
    color: var(--accent);
  }
  .crumbs span {
    margin-inline: 4px;
  }
  .head {
    padding-block: 24px 6px;
    border-bottom: 1px solid var(--border-soft);
    margin-bottom: 24px;
  }
  .head.has-art {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 26px;
    align-items: center;
  }
  .boxart {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background:
      radial-gradient(120% 120% at 80% 0%, color-mix(in srgb, var(--c1) 25%, transparent), transparent 60%),
      linear-gradient(160deg, color-mix(in srgb, var(--c2) 80%, #000), #0b0c11);
    box-shadow: var(--shadow);
  }
  .boxart img {
    width: 100%;
    max-height: 280px;
    object-fit: contain;
    padding: 14px;
  }
  @media (max-width: 560px) {
    .head.has-art {
      grid-template-columns: 130px 1fr;
      gap: 16px;
    }
  }
  .platform-pill {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--muted);
  }
  .platform-pill:hover {
    color: var(--text);
  }
  .pp-short {
    font-size: 0.55rem;
    padding: 0.45em 0.6em;
    border-radius: 7px;
    color: #fff;
    background: color-mix(in srgb, var(--c1) 35%, var(--surface-2));
    border: 1px solid color-mix(in srgb, var(--c1) 55%, var(--border));
  }
  h1 {
    font-size: clamp(1.8rem, 5vw, 2.7rem);
    margin-block: 12px 16px;
  }
  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag-genre {
    color: color-mix(in srgb, var(--c1) 70%, var(--text));
    border-color: color-mix(in srgb, var(--c1) 40%, var(--border));
  }
  .teaser {
    font-size: 1.15rem;
    line-height: 1.55;
    color: var(--text);
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 16px;
    margin-bottom: 22px;
  }
  .detail {
    font-size: 1.06rem;
  }
  .no-detail {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    padding: 18px 20px;
  }
  .no-detail a {
    color: var(--accent);
  }
  .gallery {
    margin-top: 40px;
  }
  .gallery h2 {
    font-size: 1.4rem;
    margin-bottom: 16px;
  }
  .shots {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .shots figure {
    margin: 0;
    background:
      radial-gradient(120% 120% at 80% 0%, color-mix(in srgb, var(--accent) 12%, transparent), transparent 60%),
      var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .shots img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: contain;
    background: #0b0c11;
    image-rendering: pixelated;
  }
  .shots figcaption {
    padding: 8px 12px;
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 600;
  }
  .related {
    margin-top: 48px;
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
  }
  .related h2 {
    font-size: 1.4rem;
    margin-bottom: 18px;
  }
  .back {
    margin-top: 20px;
  }
</style>
