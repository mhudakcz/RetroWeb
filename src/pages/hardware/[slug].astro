---
import Base from '../../layouts/Base.astro';
import HardwareArt from '../../components/HardwareArt.astro';
import { hardware, getHardware, HW_LEVEL_LABEL } from '../../data/hardware';
import { mdInline } from '../../lib/data';

export function getStaticPaths() {
  return hardware.map((h) => ({ params: { slug: h.slug } }));
}

const { slug } = Astro.params;
const hw = getHardware(slug!)!;
const others = hardware.filter((h) => h.slug !== hw.slug);
---

<Base
  title={hw.name}
  description={hw.tagline}
  accent={hw.color}
>
  <article class="container narrow">
    <nav class="crumbs muted" aria-label="Drobečková navigace">
      <a href="/hardware">Hardware</a> <span>/</span> <span>{hw.name}</span>
    </nav>

    <header class="head">
      <div class="art-wrap">
        <HardwareArt art={hw.art} color={hw.color} color2={hw.color2} />
      </div>
      <div class="intro">
        <p class="kind">{hw.kind}</p>
        <h1>{hw.name}</h1>
        <p class="tagline">{hw.tagline}</p>
      </div>
    </header>

    <div class="lead prose">
      {hw.intro.map((p) => <p set:html={mdInline(p)} />)}
    </div>

    <div class="panels">
      <div class="panel">
        <h3>Parametry</h3>
        <dl class="specs">
          {hw.specs.map((s) => (
            <div class="spec"><dt>{s.label}</dt><dd>{s.value}</dd></div>
          ))}
        </dl>
      </div>
      <div class="panel">
        <h3>Co utáhne</h3>
        <ul class="can">
          {hw.canPlay.map((c) => (
            <li><span class:list={['lvl', c.level]}>{HW_LEVEL_LABEL[c.level]}</span><span>{c.label}</span></li>
          ))}
        </ul>
      </div>
    </div>

    {
      hw.sections.map((sec) => (
        <section class="long">
          <h2>{sec.title}</h2>
          <div class="prose">
            {sec.body.map((p) => <p set:html={mdInline(p)} />)}
          </div>
        </section>
      ))
    }

    <section class="options">
      <h2>Možnosti &amp; tipy</h2>
      <div class="opt-grid">
        {hw.options.map((o) => (
          <div class="opt" style={`--c1:${hw.color}`}>
            <h4>{o.title}</h4>
            <p set:html={mdInline(o.text)} />
          </div>
        ))}
      </div>
    </section>

    <section class="more-hw">
      <h2>Další průvodci</h2>
      <div class="more-grid">
        {others.map((h) => (
          <a class="card more-card" href={`/hardware/${h.slug}`} style={`--c1:${h.color}`}>
            <HardwareArt art={h.art} color={h.color} color2={h.color2} />
            <div class="mc-body">
              <h3>{h.name}</h3>
              <p>{h.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </article>
</Base>

<style>
  .narrow {
    max-width: 820px;
  }
  .crumbs {
    padding-top: 26px;
    font-size: 0.86rem;
  }
  .crumbs a:hover {
    color: var(--accent);
  }
  .crumbs span {
    margin-inline: 4px;
  }
  .head {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 30px;
    align-items: center;
    padding-block: 22px 8px;
  }
  .art-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }
  .kind {
    font-family: var(--font-pixel);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: color-mix(in srgb, var(--accent) 80%, var(--text));
  }
  h1 {
    font-size: clamp(1.8rem, 5vw, 2.7rem);
    margin-block: 10px 10px;
  }
  .tagline {
    font-size: 1.15rem;
    color: var(--text);
  }
  .lead {
    margin-top: 18px;
    font-size: 1.08rem;
  }
  .prose :global(p) {
    margin-bottom: 0.95em;
    color: #d3d7e4;
  }
  .prose :global(strong) {
    color: #fff;
  }
  .panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 28px 0 8px;
  }
  .panel {
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    padding: 18px 20px;
  }
  .panel h3 {
    font-size: 1.05rem;
    margin-bottom: 12px;
  }
  .specs {
    display: grid;
    gap: 8px;
  }
  .spec {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 12px;
    font-size: 0.9rem;
  }
  .spec dt {
    color: var(--muted);
  }
  .spec dd {
    color: var(--text);
    font-weight: 500;
  }
  .can {
    display: grid;
    gap: 10px;
  }
  .can li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.92rem;
  }
  .lvl {
    flex: none;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.3em 0.6em;
    border-radius: 999px;
    min-width: 96px;
    text-align: center;
  }
  .lvl.ok {
    background: rgba(54, 226, 255, 0.16);
    color: #7ef0ff;
  }
  .lvl.most {
    background: rgba(255, 210, 62, 0.16);
    color: var(--accent-3);
  }
  .lvl.some {
    background: rgba(255, 62, 127, 0.16);
    color: #ff8fb3;
  }
  .long {
    margin-top: 30px;
  }
  .long h2 {
    font-size: clamp(1.3rem, 3vw, 1.6rem);
    margin-bottom: 12px;
  }
  .options {
    margin-top: 36px;
  }
  .options h2 {
    font-size: clamp(1.3rem, 3vw, 1.6rem);
    margin-bottom: 16px;
  }
  .opt-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 14px;
  }
  .opt {
    background: linear-gradient(180deg, var(--surface), var(--bg-2));
    border: 1px solid var(--border-soft);
    border-left: 3px solid var(--c1);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
  }
  .opt h4 {
    font-size: 0.98rem;
    margin-bottom: 6px;
  }
  .opt p {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .opt :global(strong) {
    color: var(--text);
  }
  .more-hw {
    margin-top: 44px;
    padding-top: 28px;
    border-top: 1px solid var(--border-soft);
  }
  .more-hw h2 {
    font-size: 1.4rem;
    margin-bottom: 16px;
  }
  .more-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .more-card {
    display: flex;
    flex-direction: column;
  }
  .more-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--c1) 55%, var(--border));
  }
  .mc-body {
    padding: 12px 14px 14px;
  }
  .mc-body h3 {
    font-size: 1.02rem;
  }
  .mc-body p {
    font-size: 0.86rem;
    color: var(--muted);
    margin-top: 3px;
  }
  @media (max-width: 760px) {
    .head {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .panels,
    .more-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
