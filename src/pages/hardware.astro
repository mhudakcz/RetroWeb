---
import Base from '../layouts/Base.astro';
import HardwareArt from '../components/HardwareArt.astro';
import { hardware } from '../data/hardware';
---

<Base
  title="Hardware & Batocera"
  description="Retro handheldy Anbernic RG35XX Pro a R36S a systém Batocera — samostatné průvodce: co umí, co utáhnou a jak je nastavit."
>
  <section class="container head">
    <p class="eyebrow">Na čem hrát</p>
    <h1>Hardware &amp; Batocera</h1>
    <p class="muted lead">
      Krabičky a systém, na kterých tenhle svět ožívá. Vyber si průvodce — u každého najdeš
      parametry, co reálně utáhne, možnosti a tipy.
    </p>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-hw">
        {
          hardware.map((h) => (
            <a class="card hw-card" href={`/hardware/${h.slug}`} style={`--c1:${h.color}; --c2:${h.color2}`}>
              {h.photo ? (
                <div class={`hw-photo${h.photo.fit === 'contain' ? ' contain' : ''}`}>
                  <img src={h.photo.src} alt={h.name} loading="lazy" />
                </div>
              ) : (
                <HardwareArt art={h.art} color={h.color} color2={h.color2} />
              )}
              <div class="hw-body">
                <h2>{h.name}</h2>
                <p class="muted">{h.kind}</p>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>

<style>
  .head {
    padding-block: 48px 8px;
  }
  .head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-block: 8px 12px;
  }
  .lead {
    max-width: 640px;
    font-size: 1.05rem;
  }
  .grid-hw {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 18px;
  }
  .hw-photo {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 75% 10%, color-mix(in srgb, var(--c1) 30%, transparent), transparent 60%),
      linear-gradient(160deg, var(--c2), #0b0c11);
  }
  .hw-photo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16px;
    display: block;
  }
  .hw-card {
    display: flex;
    flex-direction: column;
  }
  .hw-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--c1) 55%, var(--border));
    box-shadow: var(--shadow);
  }
  .hw-body {
    padding: 13px 15px 15px;
  }
  .hw-body h2 {
    font-size: 1rem;
    line-height: 1.25;
  }
  .hw-body .muted {
    font-size: 0.82rem;
    margin-top: 3px;
  }
</style>
