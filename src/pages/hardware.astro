---
import Base from '../layouts/Base.astro';
import HardwareArt from '../components/HardwareArt.astro';
import { hardware } from '../data/hardware';
---

<Base
  title="Hardware & Batocera"
  description="Retro handheldy Anbernic RG35XX Pro a R36S a systém Batocera — samostatné průvodce: co umí, co utáhnou a jak je nastavit."
>
  <section class="container head">
    <p class="eyebrow">Na čem hrát</p>
    <h1>Hardware &amp; Batocera</h1>
    <p class="muted lead">
      Krabičky a systém, na kterých tenhle svět ožívá. Vyber si průvodce — u každého najdeš
      parametry, co reálně utáhne, možnosti a tipy.
    </p>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid">
        {
          hardware.map((h) => (
            <a class="card device-card" href={`/hardware/${h.slug}`} style={`--c1:${h.color}`}>
              <HardwareArt art={h.art} color={h.color} color2={h.color2} />
              <div class="body">
                <p class="kind">{h.kind}</p>
                <h2>{h.name}</h2>
                <p class="tagline">{h.tagline}</p>
                <span class="more">Číst průvodce →</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Base>

<style>
  .head {
    padding-block: 48px 8px;
  }
  .head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-block: 8px 12px;
  }
  .lead {
    max-width: 640px;
    font-size: 1.05rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
  }
  .device-card {
    display: flex;
    flex-direction: column;
  }
  .device-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--c1) 55%, var(--border));
    box-shadow: var(--shadow);
  }
  .body {
    padding: 16px 18px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }
  .kind {
    font-family: var(--font-pixel);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: color-mix(in srgb, var(--c1) 75%, var(--text));
  }
  h2 {
    font-size: 1.25rem;
  }
  .tagline {
    color: var(--muted);
    font-size: 0.95rem;
    flex: 1;
  }
  .more {
    margin-top: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    color: color-mix(in srgb, var(--c1) 70%, var(--text));
  }
</style>
