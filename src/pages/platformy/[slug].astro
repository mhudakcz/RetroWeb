---
import Base from '../../layouts/Base.astro';
import PlatformEmblem from '../../components/PlatformEmblem.astro';
import GameCard from '../../components/GameCard.astro';
import { platforms, getPlatform, TYPE_LABEL, mdBlock, platformNeighbors } from '../../lib/data';

export function getStaticPaths() {
  return platforms.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const platform = getPlatform(slug!)!;
const history = mdBlock(platform.history);
const withDetail = platform.games.filter((g) => g.detail).length;
const { prev, next } = platformNeighbors(platform.slug);
---

<Base
  title={platform.name}
  description={`${platform.name} (${platform.maker}, ${platform.year}) — historie platformy a ${platform.gameCount} doporučených her.`}
  accent={platform.color}
>
  <section class="container">
    <nav class="crumbs muted" aria-label="Drobečková navigace">
      <a href="/platformy">Platformy</a> <span>/</span> <span>{platform.name}</span>
    </nav>

    <div class="hero">
      <div class="emblem-wrap">
        <PlatformEmblem platform={platform} size="hero" />
      </div>
      <div class="intro">
        <p class="eyebrow">{TYPE_LABEL[platform.type]}</p>
        <h1>{platform.name}</h1>
        <div class="facts">
          <span class="tag">{platform.maker}</span>
          <span class="tag">Rok {platform.year}</span>
          <span class="tag">{platform.gameCount} her</span>
          {withDetail > 0 && <span class="tag">{withDetail} s komentářem</span>}
        </div>
      </div>
    </div>
  </section>

  {
    history && (
      <section class="section history-sec">
        <div class="container narrow">
          <h2 class="sec-title">Historie &amp; kontext</h2>
          <div class="prose" set:html={history} />
        </div>
      </section>
    )
  }

  <section class="section">
    <div class="container">
      <h2 class="sec-title">Doporučené hry <span class="muted">({platform.gameCount})</span></h2>
      <div class="grid grid-games">
        {platform.games.map((g) => <GameCard game={g} platform={platform} />)}
      </div>
    </div>
  </section>

  <nav class="container pager" aria-label="Další platformy">
    {prev ? (
      <a class="pager-link prev" href={`/platformy/${prev.slug}`} style={`--c1:${prev.color}`}>
        <span class="dir">← Předchozí</span>
        <span class="pn">{prev.name}</span>
      </a>
    ) : <span />}
    {next ? (
      <a class="pager-link next" href={`/platformy/${next.slug}`} style={`--c1:${next.color}`}>
        <span class="dir">Další →</span>
        <span class="pn">{next.name}</span>
      </a>
    ) : <span />}
  </nav>
</Base>

<style>
  .crumbs {
    padding-top: 26px;
    font-size: 0.86rem;
  }
  .crumbs a:hover {
    color: var(--accent);
  }
  .crumbs span {
    margin-inline: 4px;
  }
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) 1.2fr;
    gap: 32px;
    align-items: center;
    padding-block: 22px 8px;
  }
  .emblem-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-block: 8px 16px;
  }
  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .narrow {
    max-width: 760px;
  }
  .sec-title {
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    margin-bottom: 18px;
  }
  .history-sec {
    background: var(--bg-2);
    border-block: 1px solid var(--border-soft);
  }
  .prose {
    font-size: 1.04rem;
  }
  .pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    padding-block: 38px 56px;
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--c1, var(--accent));
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .pager-link.next {
    text-align: right;
    border-left: 1px solid var(--border);
    border-right: 4px solid var(--c1, var(--accent));
  }
  .pager-link:hover {
    transform: translateY(-2px);
    border-color: var(--c1, var(--accent));
  }
  .pager-link .dir {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 600;
  }
  .pager-link .pn {
    font-weight: 700;
    font-size: 1.05rem;
  }
  @media (max-width: 780px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .pager {
      grid-template-columns: 1fr;
    }
  }
</style>
