---
import Base from '../../layouts/Base.astro';
import PlatformEmblem from '../../components/PlatformEmblem.astro';
import GameCard from '../../components/GameCard.astro';
import { platforms, getPlatform, TYPE_LABEL, mdBlock, platformNeighbors, GENRE_CATS, genreCats } from '../../lib/data';

export function getStaticPaths() {
  return platforms.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const platform = getPlatform(slug!)!;
const history = mdBlock(platform.history);
const withDetail = platform.games.filter((g) => g.detail).length;
const { prev, next } = platformNeighbors(platform.slug);

// Žánrový filtr – jen kategorie, které se u her této platformy reálně vyskytují
const genreCount = (k: string) => platform.games.filter((g) => genreCats(g.genre).includes(k)).length;
const genreOptions = GENRE_CATS.filter(([k]) => genreCount(k) > 0).map(([k, label]) => [k, `${label} (${genreCount(k)})`] as [string, string]);
const showGenreFilter = platform.games.length > 6 && genreOptions.length > 1;
---

<Base
  title={platform.name}
  description={`${platform.name} (${platform.maker}, ${platform.year}) — historie platformy a ${platform.gameCount} doporučených her.`}
  accent={platform.color}
>
  <section class="container">
    <nav class="crumbs muted" aria-label="Drobečková navigace">
      <a href="/platformy">Platformy</a> <span>/</span> <span>{platform.name}</span>
    </nav>

    <div class="hero">
      <div class="emblem-wrap">
        <PlatformEmblem platform={platform} size="hero" />
      </div>
      <div class="intro">
        <p class="eyebrow">{TYPE_LABEL[platform.type]}</p>
        <h1>{platform.name}</h1>
        <div class="facts">
          <span class="tag">{platform.maker}</span>
          <span class="tag">Rok {platform.year}</span>
          <span class="tag">{platform.gameCount} her</span>
          {withDetail > 0 && <span class="tag">{withDetail} s komentářem</span>}
        </div>
      </div>
    </div>
  </section>

  {
    history && (
      <section class="section history-sec">
        <div class="container narrow">
          <h2 class="sec-title">Historie &amp; kontext</h2>
          <div class="prose" set:html={history} />
        </div>
      </section>
    )
  }

  <nav class="container pager" aria-label="Další platformy">
    {prev ? (
      <a class="pager-link prev" href={`/platformy/${prev.slug}`} style={`--c1:${prev.color}`}>
        <span class="dir">← Předchozí platforma</span>
        <span class="pn">{prev.name}</span>
      </a>
    ) : <span />}
    {next ? (
      <a class="pager-link next" href={`/platformy/${next.slug}`} style={`--c1:${next.color}`}>
        <span class="dir">Další platforma →</span>
        <span class="pn">{next.name}</span>
      </a>
    ) : <span />}
  </nav>

  <section class="section">
    <div class="container">
      <div class="games-head">
        <h2 class="sec-title">Doporučené hry <span class="muted">(<span id="gcount">{platform.gameCount}</span>)</span></h2>
        {showGenreFilter && (
          <select id="genre" aria-label="Filtrovat žánr">
            <option value="">Všechny žánry</option>
            {genreOptions.map(([k, label]) => <option value={k}>{label}</option>)}
          </select>
        )}
      </div>
      <div class="grid grid-games" id="pgrid">
        {platform.games.map((g) => (
          <div class="pcell" data-genre={genreCats(g.genre).join(' ')}>
            <GameCard game={g} platform={platform} />
          </div>
        ))}
      </div>
      <p class="empty muted" id="pempty" hidden>Žádná hra v tomto žánru.</p>
    </div>
  </section>

  {showGenreFilter && (
    <script is:inline define:vars={{ total: platform.gameCount }}>
      const sel = document.getElementById('genre');
      const cells = Array.from(document.querySelectorAll('#pgrid .pcell'));
      const countEl = document.getElementById('gcount');
      const emptyEl = document.getElementById('pempty');
      sel?.addEventListener('change', () => {
        const g = sel.value;
        let shown = 0;
        for (const c of cells) {
          const ok = !g || (c.dataset.genre || '').split(' ').includes(g);
          c.hidden = !ok;
          if (ok) shown++;
        }
        countEl.textContent = g ? shown : total;
        emptyEl.hidden = shown !== 0;
      });
    </script>
  )}
</Base>

<style>
  .crumbs {
    padding-top: 26px;
    font-size: 0.86rem;
  }
  .crumbs a:hover {
    color: var(--accent);
  }
  .crumbs span {
    margin-inline: 4px;
  }
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) 1.2fr;
    gap: 32px;
    align-items: center;
    padding-block: 22px 8px;
  }
  .emblem-wrap {
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-block: 8px 16px;
  }
  .facts {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .narrow {
    max-width: 760px;
  }
  .sec-title {
    font-size: clamp(1.3rem, 3vw, 1.7rem);
    margin-bottom: 18px;
  }
  .games-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .games-head .sec-title {
    margin-bottom: 0;
  }
  #genre {
    height: 42px;
    padding: 0 14px;
    border-radius: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-size: 0.95rem;
    font-family: inherit;
  }
  #genre:focus {
    border-color: var(--accent);
    outline: none;
  }
  .games-head + .grid-games {
    margin-top: 18px;
  }
  .pcell[hidden] {
    display: none;
  }
  .empty {
    text-align: center;
    padding: 36px 0;
  }
  .history-sec {
    background: var(--bg-2);
    border-block: 1px solid var(--border-soft);
  }
  .prose {
    font-size: 1.04rem;
  }
  .pager {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    padding-block: 32px 8px;
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 20px;
    border-radius: var(--radius);
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 4px solid var(--c1, var(--accent));
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .pager-link.next {
    text-align: right;
    border-left: 1px solid var(--border);
    border-right: 4px solid var(--c1, var(--accent));
  }
  .pager-link:hover {
    transform: translateY(-2px);
    border-color: var(--c1, var(--accent));
  }
  .pager-link .dir {
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 600;
  }
  .pager-link .pn {
    font-weight: 700;
    font-size: 1.05rem;
  }
  @media (max-width: 780px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .pager {
      grid-template-columns: 1fr;
    }
  }
</style>
