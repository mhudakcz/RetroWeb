---
import { FLAG_LABEL, mdInline, type Game, type Platform } from '../lib/data';

interface Props {
  game: Game;
  platform: Platform;
  showPlatform?: boolean;
}
const { game, platform, showPlatform = false } = Astro.props;

// Krátký popis: teaser, jinak useknutý detail.
let blurb = game.teaser;
if (!blurb && game.detail) {
  const plain = game.detail.replace(/[*_\x60]/g, '');
  blurb = plain.length > 150 ? plain.slice(0, 150).trimEnd() + '…' : plain;
}
const hasInfo = Boolean(game.detail);
---

<a class="card game-card" href={`/hry/${game.slug}`} style={`--c1:${platform.color}; --c2:${platform.color2}`}>
  <div class:list={['thumb', { 'is-empty': !game.image }]}>
    {
      game.image ? (
        <img src={game.image} alt={`${game.name.replace(/[*_\x60]/g, '')} – boxart`} loading="lazy" decoding="async" />
      ) : (
        <span class="thumb-tag pixel">{platform.short}</span>
      )
    }
    {showPlatform && game.image && <span class="thumb-platform pixel">{platform.short}</span>}
  </div>

  <div class="body-pad">
  <div class="top">
    <h3 set:html={mdInline(game.name)} />
    {hasInfo && <span class="dot" title="Má detailní komentář" aria-hidden="true"></span>}
  </div>

  <div class="tags">
    {showPlatform && <span class="tag tag-platform">{platform.short}</span>}
    {game.genre && <span class="tag tag-genre">{game.genre}</span>}
    {game.length && <span class="tag">⏱ {game.length}</span>}
    {game.flags.map((f) => <span class="tag tag-flag">{FLAG_LABEL[f]}</span>)}
  </div>

  {blurb && <p class="blurb" set:html={mdInline(blurb)} />}
  </div>
</a>

<style>
  .game-card {
    display: flex;
    flex-direction: column;
  }
  .game-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--c1) 55%, var(--border));
    box-shadow: var(--shadow);
  }
  .thumb {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 80% 0%, color-mix(in srgb, var(--c1) 22%, transparent), transparent 60%),
      linear-gradient(160deg, color-mix(in srgb, var(--c2) 80%, #000), #0b0c11);
    border-bottom: 1px solid var(--border-soft);
    display: grid;
    place-items: center;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12px;
  }
  .thumb-tag {
    font-size: 1rem;
    color: #fff;
    opacity: 0.85;
    text-shadow: 0 2px 0 rgba(0, 0, 0, 0.35), 0 0 18px color-mix(in srgb, var(--c1) 70%, transparent);
  }
  .thumb-platform {
    position: absolute;
    top: 8px;
    left: 8px;
    font-size: 0.5rem;
    color: #fff;
    padding: 0.4em 0.55em;
    border-radius: 6px;
    background: color-mix(in srgb, var(--c1) 45%, rgba(0, 0, 0, 0.6));
    backdrop-filter: blur(3px);
  }
  .body-pad {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 14px 16px 16px;
    flex: 1;
  }
  .top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 10px;
  }
  h3 {
    font-size: 1.02rem;
    line-height: 1.3;
  }
  .dot {
    flex: none;
    margin-top: 6px;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--c1) 80%, #fff);
    box-shadow: 0 0 10px var(--c1);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag-platform {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: #fff;
    background: color-mix(in srgb, var(--c1) 30%, var(--surface-2));
    border-color: color-mix(in srgb, var(--c1) 50%, var(--border));
  }
  .tag-genre {
    color: color-mix(in srgb, var(--c1) 65%, var(--text));
    border-color: color-mix(in srgb, var(--c1) 35%, var(--border));
  }
  .tag-flag {
    background: var(--surface);
  }
  .blurb {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.55;
  }
  .blurb :global(strong) {
    color: var(--text);
  }
</style>
