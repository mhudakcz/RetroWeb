---
// Stylizované SVG ilustrace zařízení (bez nutnosti chráněných fotografií).
interface Props {
  art: 'handheld-h' | 'handheld-v' | 'batocera' | 'pi' | 'android' | 'pc' | 'mobile';
  color: string;
  color2: string;
}
const { art, color, color2 } = Astro.props;
const id = Math.random().toString(36).slice(2, 8);
---

<div class="art scanlines" style={`--c1:${color}; --c2:${color2}`}>
  <svg viewBox="0 0 320 200" role="img" aria-hidden="true">
    <defs>
      <linearGradient id={`scr-${id}`} x1="0" y1="0" x2="0.6" y2="1">
        <stop offset="0" stop-color="#ffffff" stop-opacity="0.55" />
        <stop offset="0.5" stop-color="#ffffff" stop-opacity="0.12" />
        <stop offset="1" stop-color="#ffffff" stop-opacity="0" />
      </linearGradient>
    </defs>

    {
      art === 'handheld-h' && (
        <g stroke="#0c0d12" stroke-width="2">
          <rect x="40" y="46" width="240" height="108" rx="20" fill="#23262f" />
          <rect x="118" y="60" width="84" height="80" rx="6" fill="var(--c1)" />
          <rect x="118" y="60" width="84" height="80" rx="6" fill={`url(#scr-${id})`} stroke="none" />
          {/* d-pad */}
          <rect x="74" y="92" width="10" height="30" rx="2" fill="#3a3f4d" />
          <rect x="64" y="102" width="30" height="10" rx="2" fill="#3a3f4d" />
          {/* tlačítka */}
          <circle cx="236" cy="96" r="7" fill="var(--c1)" />
          <circle cx="252" cy="112" r="7" fill="#3a3f4d" />
          <circle cx="220" cy="112" r="7" fill="#3a3f4d" />
          <circle cx="236" cy="128" r="7" fill="#3a3f4d" />
          {/* sticky */}
          <circle cx="84" cy="138" r="9" fill="#2c303c" />
          <circle cx="236" cy="70" r="0" />
        </g>
      )
    }

    {
      art === 'handheld-v' && (
        <g stroke="#0c0d12" stroke-width="2">
          <rect x="108" y="22" width="104" height="156" rx="16" fill="#23262f" />
          <rect x="124" y="34" width="72" height="70" rx="5" fill="var(--c1)" />
          <rect x="124" y="34" width="72" height="70" rx="5" fill={`url(#scr-${id})`} stroke="none" />
          {/* d-pad */}
          <rect x="131" y="128" width="8" height="24" rx="2" fill="#3a3f4d" />
          <rect x="123" y="136" width="24" height="8" rx="2" fill="#3a3f4d" />
          {/* tlačítka */}
          <circle cx="184" cy="132" r="6" fill="var(--c1)" />
          <circle cx="172" cy="144" r="6" fill="#3a3f4d" />
          <circle cx="196" cy="144" r="6" fill="#3a3f4d" />
          <circle cx="184" cy="156" r="6" fill="#3a3f4d" />
        </g>
      )
    }

    {
      art === 'batocera' && (
        <g stroke="#0c0d12" stroke-width="2">
          {/* monitor */}
          <rect x="60" y="34" width="200" height="120" rx="10" fill="#23262f" />
          <rect x="72" y="46" width="176" height="84" rx="4" fill="var(--c1)" />
          <rect x="72" y="46" width="176" height="84" rx="4" fill={`url(#scr-${id})`} stroke="none" />
          {/* dlaždice na obrazovce */}
          <rect x="82" y="56" width="36" height="28" rx="3" fill="#0c0d12" opacity="0.35" />
          <rect x="124" y="56" width="36" height="28" rx="3" fill="#0c0d12" opacity="0.25" />
          <rect x="166" y="56" width="36" height="28" rx="3" fill="#0c0d12" opacity="0.35" />
          <rect x="82" y="92" width="120" height="8" rx="3" fill="#0c0d12" opacity="0.3" />
          {/* stojan */}
          <rect x="150" y="154" width="20" height="16" fill="#23262f" />
          <rect x="120" y="168" width="80" height="8" rx="3" fill="#2c303c" />
        </g>
      )
    }

    {
      art === 'pi' && (
        <g stroke="#0c0d12" stroke-width="2">
          {/* deska */}
          <rect x="56" y="56" width="208" height="88" rx="8" fill="#1f7a3f" />
          {/* GPIO piny */}
          <rect x="68" y="64" width="120" height="10" rx="2" fill="#2c303c" />
          {/* SoC */}
          <rect x="120" y="92" width="40" height="40" rx="4" fill={`url(#scr-${id})`} stroke="none" />
          <rect x="120" y="92" width="40" height="40" rx="4" fill="none" />
          {/* porty */}
          <rect x="232" y="86" width="22" height="16" rx="2" fill="#2c303c" />
          <rect x="232" y="110" width="22" height="16" rx="2" fill="#2c303c" />
          <rect x="70" y="120" width="30" height="14" rx="2" fill="#2c303c" />
        </g>
      )
    }

    {
      art === 'android' && (
        <g stroke="#0c0d12" stroke-width="2">
          {/* TV box */}
          <rect x="78" y="96" width="164" height="56" rx="10" fill="#23262f" />
          <circle cx="100" cy="124" r="6" fill={`url(#scr-${id})`} stroke="none" />
          <circle cx="100" cy="124" r="6" fill="none" />
          <rect x="210" y="118" width="22" height="12" rx="2" fill="#2c303c" />
          {/* obrazovka / play */}
          <rect x="116" y="34" width="88" height="52" rx="6" fill={`url(#scr-${id})`} stroke="none" />
          <rect x="116" y="34" width="88" height="52" rx="6" fill="none" />
          <path d="M150 48l22 12-22 12z" fill="#0c0d12" opacity="0.55" stroke="none" />
        </g>
      )
    }

    {
      art === 'pc' && (
        <g stroke="#0c0d12" stroke-width="2">
          {/* monitor */}
          <rect x="36" y="40" width="170" height="110" rx="8" fill="#23262f" />
          <rect x="48" y="52" width="146" height="74" rx="4" fill={`url(#scr-${id})`} stroke="none" />
          <rect x="48" y="52" width="146" height="74" rx="4" fill="none" />
          <rect x="108" y="150" width="26" height="14" fill="#23262f" />
          <rect x="86" y="164" width="70" height="8" rx="3" fill="#2c303c" />
          {/* tower */}
          <rect x="222" y="58" width="58" height="106" rx="8" fill="#23262f" />
          <circle cx="251" cy="74" r="4" fill={`url(#scr-${id})`} stroke="none" />
          <rect x="236" y="92" width="30" height="6" rx="2" fill="#2c303c" />
          <rect x="236" y="104" width="30" height="6" rx="2" fill="#2c303c" />
        </g>
      )
    }

    {
      art === 'mobile' && (
        <g stroke="#0c0d12" stroke-width="2">
          {/* tablet */}
          <rect x="60" y="44" width="104" height="120" rx="12" fill="#23262f" />
          <rect x="70" y="54" width="84" height="100" rx="4" fill={`url(#scr-${id})`} stroke="none" />
          <rect x="70" y="54" width="84" height="100" rx="4" fill="none" />
          {/* telefon */}
          <rect x="180" y="62" width="64" height="102" rx="12" fill="#23262f" />
          <rect x="188" y="74" width="48" height="72" rx="3" fill={`url(#scr-${id})`} stroke="none" />
          <rect x="188" y="74" width="48" height="72" rx="3" fill="none" />
          <path d="M204 96l16 10-16 10z" fill="#0c0d12" opacity="0.5" stroke="none" />
          <circle cx="212" cy="156" r="3" fill="#2c303c" />
        </g>
      )
    }
  </svg>
</div>

<style>
  .art {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 75% 10%, color-mix(in srgb, var(--c1) 30%, transparent), transparent 60%),
      linear-gradient(160deg, var(--c2), #0b0c11);
    display: grid;
    place-items: center;
    aspect-ratio: 16 / 10;
  }
  .art svg {
    width: 86%;
    filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.45));
  }
</style>
