---
const path = Astro.url.pathname;
const isActive = (p: string) => (p === '/' ? path === '/' : path.startsWith(p));
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="logo" aria-label="RetroWeb – domů">
      <span class="logo-mark pixel">RW</span>
      <span class="logo-text">Retro<span class="accent">Web</span></span>
    </a>
    <nav id="nav" class="nav" aria-label="Hlavní navigace">
      <a href="/" class:list={['nav-link', { active: isActive('/') }]}>Domů</a>
      <a href="/platformy" class:list={['nav-link', { active: isActive('/platformy') }]}>Platformy</a>
      <a href="/hry" class:list={['nav-link', { active: isActive('/hry') }]}>Hry</a>
      <a href="/studia" class:list={['nav-link', { active: isActive('/studia') }]}>Studia</a>
      <a href="/hardware" class:list={['nav-link', { active: isActive('/hardware') }]}>Hardware</a>
      <a href="/o-projektu" class:list={['nav-link', { active: isActive('/o-projektu') }]}>O projektu</a>
      <button id="theme-nav" class="nav-link theme-nav" type="button">
        <span class="t-dark">🌙 Noční režim</span><span class="t-light">☀️ Denní režim</span>
      </button>
    </nav>
    <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Přepnout denní/noční režim" title="Denní / noční režim">
      <span class="t-dark">🌙</span><span class="t-light">☀️</span>
    </button>
    <button id="nav-toggle" class="nav-toggle" type="button" aria-label="Otevřít menu" aria-expanded="false" aria-controls="nav">
      <span class="bars" aria-hidden="true"></span>
    </button>
  </div>
</header>

<script is:inline>
  (function () {
    function toggleTheme() {
      var light = document.documentElement.getAttribute('data-theme') === 'light';
      if (light) {
        document.documentElement.removeAttribute('data-theme');
        try { localStorage.setItem('theme', 'dark'); } catch (e) {}
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        try { localStorage.setItem('theme', 'light'); } catch (e) {}
      }
    }
    var btn = document.getElementById('theme-toggle');
    if (btn) btn.addEventListener('click', toggleTheme);
    var btnNav = document.getElementById('theme-nav');
    if (btnNav) btnNav.addEventListener('click', toggleTheme);

    var navBtn = document.getElementById('nav-toggle');
    var nav = document.getElementById('nav');
    if (navBtn && nav) {
      var close = function () {
        nav.classList.remove('open');
        navBtn.setAttribute('aria-expanded', 'false');
        navBtn.setAttribute('aria-label', 'Otevřít menu');
      };
      navBtn.addEventListener('click', function () {
        var open = nav.classList.toggle('open');
        navBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
        navBtn.setAttribute('aria-label', open ? 'Zavřít menu' : 'Otevřít menu');
      });
      // klik mimo / na odkaz menu zavře
      nav.addEventListener('click', function (e) {
        if (e.target && e.target.closest && e.target.closest('a')) close();
      });
      document.addEventListener('click', function (e) {
        if (nav.classList.contains('open') && !nav.contains(e.target) && e.target !== navBtn && !navBtn.contains(e.target)) close();
      });
    }
  })();
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(11, 12, 17, 0.78);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-soft);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 16px;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-weight: 800;
    font-size: 1.18rem;
  }
  .logo-mark {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 9px;
    font-size: 0.66rem;
    color: #1a0710;
    background: linear-gradient(135deg, var(--accent), #ff8fb3);
    box-shadow: 0 0 0 1px rgba(255, 62, 127, 0.4), 0 6px 18px -6px var(--accent);
  }
  .logo .accent {
    color: var(--accent);
  }
  .nav {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .nav-link {
    padding: 0.5em 0.85em;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--muted);
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--surface);
  }
  .nav-link.active {
    color: var(--text);
    background: var(--surface-2);
  }
  .logo {
    margin-right: auto;
  }
  .theme-toggle {
    flex: none;
    width: 38px;
    height: 38px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 1.02rem;
    line-height: 1;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .theme-toggle:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .theme-toggle .t-light {
    display: none;
  }
  :root[data-theme='light'] .theme-toggle .t-dark {
    display: none;
  }
  :root[data-theme='light'] .theme-toggle .t-light {
    display: inline;
  }
  :root[data-theme='light'] .site-header {
    background: rgba(255, 255, 255, 0.82);
  }

  /* přepínač režimu uvnitř mobilního menu (skrytý na desktopu) */
  .theme-nav {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    font: inherit;
    text-align: left;
  }
  .theme-nav .t-light {
    display: none;
  }
  :root[data-theme='light'] .theme-nav .t-dark {
    display: none;
  }
  :root[data-theme='light'] .theme-nav .t-light {
    display: inline;
  }

  /* hamburger – skrytý na desktopu */
  .nav-toggle {
    display: none;
    flex: none;
    width: 38px;
    height: 38px;
    place-items: center;
    border-radius: 9px;
    border: 1px solid var(--border);
    background: var(--surface);
    cursor: pointer;
  }
  .nav-toggle .bars,
  .nav-toggle .bars::before,
  .nav-toggle .bars::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-toggle .bars {
    position: relative;
  }
  .nav-toggle .bars::before {
    position: absolute;
    top: -6px;
  }
  .nav-toggle .bars::after {
    position: absolute;
    top: 6px;
  }
  .nav-toggle[aria-expanded='true'] .bars {
    background: transparent;
  }
  .nav-toggle[aria-expanded='true'] .bars::before {
    top: 0;
    transform: rotate(45deg);
  }
  .nav-toggle[aria-expanded='true'] .bars::after {
    top: 0;
    transform: rotate(-45deg);
  }

  @media (max-width: 760px) {
    .nav-toggle {
      display: grid;
    }
    #theme-toggle {
      display: none;
    }
    .theme-nav {
      display: block;
      margin-top: 6px;
      border-top: 1px solid var(--border-soft);
      padding-top: 12px;
      border-radius: 0;
    }
    .nav {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 2px;
      padding: 10px 16px 16px;
      background: var(--surface);
      border-bottom: 1px solid var(--border-soft);
      box-shadow: var(--shadow);
      display: none;
    }
    .nav.open {
      display: flex;
    }
    .nav-link {
      padding: 0.7em 0.85em;
      font-size: 0.98rem;
      width: 100%;
    }
  }
  @media (max-width: 380px) {
    .logo-text {
      display: none;
    }
  }
</style>
